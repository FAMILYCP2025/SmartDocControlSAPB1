{
  "_comment": "Copy to appsettings.PRD.json and fill in real values. Do NOT commit real credentials. IgnoreSslErrors MUST be false in PRD.",
  "Sap": {
    "BaseUrl": "https://<sap-prd-host>:50000/b1s/v1/",
    "CompanyDb": "<COMPANY_DB>",
    "Username": "<SERVICE_USER>",
    "PasswordEnvironmentVariable": "SAP_AUTOCLOSE_PASSWORD",
    "IgnoreSslErrors": false,
    "TimeoutSeconds": 60
  },
  "Execution": {
    "DefaultSimulation": true,
    "MaxRetries": 3,
    "RetryDelaySeconds": 2,
    "StaleRunThresholdHours": 6
  },
  "Logging": {
    "LogPath": "C:\\SmartDocControl\\Logs\\",
    "PendingFunctionalLogPath": "C:\\SmartDocControl\\PendingLogs\\",
    "DebugMode": false
  }
}
