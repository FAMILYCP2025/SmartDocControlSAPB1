// =============================================================================
// UDT: @JCA_DLC_RUN — Resumen de ejecución por corrida
// MVP: CRÍTICA. La aplicación abortará si esta UDT no existe en SAP B1.
// Documentación: PRD sección 12.5
// NOTA: El Code de cada registro es el RunId (UUID generado por la app).
//       Un registro con U_Status = RUNNING indica ejecución activa.
//       El LockManager revisa esta tabla al arrancar para prevenir doble ejecución.
// =============================================================================

// PASO 1: Crear la tabla
// POST https://{server}:50000/b1s/v1/UserTablesMD
{
  "TableName": "JCA_DLC_RUN",
  "TableDescription": "Smart Doc Control - Resumen de ejecucion",
  "TableType": "bott_MasterData"
}

// PASO 2: Campos

{ "TableName": "@JCA_DLC_RUN", "Name": "StartedAt", "Description": "Fecha y hora de inicio", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_RUN", "Name": "FinishedAt", "Description": "Fecha y hora de fin", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_RUN", "Name": "Status", "Description": "Estado: RUNNING/FINISHED/ERROR/STALE", "Type": "db_Alpha", "Size": 20 }

{ "TableName": "@JCA_DLC_RUN", "Name": "CompanyDB", "Description": "Sociedad SAP B1", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_RUN", "Name": "Env", "Description": "Ambiente: DEV/TST/PRD", "Type": "db_Alpha", "Size": 10 }

{ "TableName": "@JCA_DLC_RUN", "Name": "TotalCandidates", "Description": "Total documentos candidatos evaluados", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_RUN", "Name": "TotalClosed", "Description": "Total documentos cerrados correctamente", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_RUN", "Name": "TotalSimulated", "Description": "Total documentos simulados (no cerrados)", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_RUN", "Name": "TotalSkipped", "Description": "Total documentos omitidos por regla", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_RUN", "Name": "TotalErrors", "Description": "Total documentos con error tecnico", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_RUN", "Name": "DurationSec", "Description": "Duracion total de la ejecucion en segundos", "Type": "db_Numeric" }
