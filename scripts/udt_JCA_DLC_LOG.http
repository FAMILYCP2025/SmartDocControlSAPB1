POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_LOG",
  "Name": "DateTime",
  "Description": "Fecha y hora del registro",
  "Type": "db_Date"
}

