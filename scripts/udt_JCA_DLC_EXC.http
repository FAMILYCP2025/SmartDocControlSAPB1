@baseUrl = https://sap-server:50000/b1s/v1
@session = replace-with-B1SESSION-cookie

# =============================================================================
# UDT: @JCA_DLC_EXC — Exclusiones de documentos/socios
# MVP: CRÍTICA. La aplicación abortará si esta UDT no existe en SAP B1.
# Creación: Ejecutar los requests en orden como usuario B1 Admin.
# Documentación: PRD sección 12.3
# =============================================================================


### PASO 1 — Crear tabla JCA_DLC_EXC
POST {{baseUrl}}/UserTablesMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "JCA_DLC_EXC",
  "TableDescription": "Smart Doc Control - Exclusiones",
  "TableType": "bott_MasterData"
}


# =============================================================================
# PASO 2 — Crear campos (ejecutar cada request por separado)
# =============================================================================

### Campo U_Active — Exclusion activa
POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_EXC",
  "Name": "Active",
  "Description": "Exclusion activa (Y/N)",
  "Type": "db_Alpha",
  "Size": 1
}

### Campo U_ObjType — Tipo objeto SAP o ALL
POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_EXC",
  "Name": "ObjType",
  "Description": "Tipo objeto SAP o ALL para todos",
  "Type": "db_Alpha",
  "Size": 20
}

### Campo U_ExcType — Tipo de exclusion
POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_EXC",
  "Name": "ExcType",
  "Description": "Tipo de exclusion: CardCode/GroupCode/SlpCode/BPLId",
  "Type": "db_Alpha",
  "Size": 20
}

### Campo U_ExcValue — Valor excluido
POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_EXC",
  "Name": "ExcValue",
  "Description": "Valor excluido (ej. C001 para CardCode)",
  "Type": "db_Alpha",
  "Size": 50
}

### Campo U_Reason — Motivo de exclusion
POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_EXC",
  "Name": "Reason",
  "Description": "Motivo de exclusion",
  "Type": "db_Memo"
}
