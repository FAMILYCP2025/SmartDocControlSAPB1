// =============================================================================
// UDT: @JCA_DLC_LOG — Log detalle por documento procesado
// MVP: CRÍTICA. La aplicación abortará si esta UDT no existe en SAP B1.
// Documentación: PRD sección 12.4
// NOTA: Esta UDT acumula un registro por documento por ejecución.
//       Planificar limpieza periódica en producción.
// =============================================================================

// PASO 1: Crear la tabla
// POST https://{server}:50000/b1s/v1/UserTablesMD
{
  "TableName": "JCA_DLC_LOG",
  "TableDescription": "Smart Doc Control - Log detalle",
  "TableType": "bott_MasterData"
}

// PASO 2: Campos

{ "TableName": "@JCA_DLC_LOG", "Name": "RunId", "Description": "ID unico de ejecucion", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_LOG", "Name": "DateTime", "Description": "Fecha y hora del registro", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_LOG", "Name": "Env", "Description": "Ambiente: DEV/TST/PRD", "Type": "db_Alpha", "Size": 10 }

{ "TableName": "@JCA_DLC_LOG", "Name": "CompanyDB", "Description": "Nombre de la sociedad SAP B1", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_LOG", "Name": "ObjType", "Description": "Tipo de objeto SAP", "Type": "db_Alpha", "Size": 20 }

{ "TableName": "@JCA_DLC_LOG", "Name": "EntitySet", "Description": "EntitySet Service Layer", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_LOG", "Name": "DocEntry", "Description": "DocEntry del documento", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_LOG", "Name": "DocNum", "Description": "DocNum del documento", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_LOG", "Name": "CardCode", "Description": "Codigo del socio de negocio", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_LOG", "Name": "CardName", "Description": "Nombre del socio de negocio", "Type": "db_Alpha", "Size": 100 }

{ "TableName": "@JCA_DLC_LOG", "Name": "DocDate", "Description": "Fecha del documento", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_LOG", "Name": "DueDate", "Description": "Fecha de vencimiento", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_LOG", "Name": "BaseDate", "Description": "Fecha usada para calcular antiguedad", "Type": "db_Date" }

{ "TableName": "@JCA_DLC_LOG", "Name": "DaysCalc", "Description": "Dias calculados de antiguedad", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_LOG", "Name": "RuleCode", "Description": "Codigo de regla aplicada", "Type": "db_Alpha", "Size": 50 }

{ "TableName": "@JCA_DLC_LOG", "Name": "Result", "Description": "Resultado: CLOSED/SIMULATED/SKIPPED_*/ERROR", "Type": "db_Alpha", "Size": 30 }

{ "TableName": "@JCA_DLC_LOG", "Name": "Message", "Description": "Mensaje descriptivo del resultado", "Type": "db_Memo" }

{ "TableName": "@JCA_DLC_LOG", "Name": "HttpStatus", "Description": "HTTP status code de Service Layer", "Type": "db_Numeric" }

{ "TableName": "@JCA_DLC_LOG", "Name": "Attempts", "Description": "Numero de intentos realizados", "Type": "db_Numeric" }

// U_Request y U_Response: solo se completan en errores o modo debug
// Considerar impacto de tamaño en HANA si se activa debug masivo
{ "TableName": "@JCA_DLC_LOG", "Name": "Request", "Description": "JSON request Service Layer (solo errores/debug)", "Type": "db_Memo" }

{ "TableName": "@JCA_DLC_LOG", "Name": "Response", "Description": "JSON response Service Layer (solo errores/debug)", "Type": "db_Memo" }
