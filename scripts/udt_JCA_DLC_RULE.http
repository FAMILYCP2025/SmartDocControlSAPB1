POST {{baseUrl}}/UserFieldsMD
Cookie: B1SESSION={{session}}
Content-Type: application/json

{
  "TableName": "@JCA_DLC_RULE",
  "Name": "ObjType",
  "Description": "Tipo de objeto SAP (17/22/23/540000006)",
  "Type": "db_Alpha",
  "Size": 20
}

